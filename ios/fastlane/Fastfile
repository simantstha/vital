default_platform(:ios)

APP_IDENTIFIER = "com.simantstha.vital".freeze

platform :ios do
  desc "Build a Release archive and upload it to TestFlight"
  desc "Auth: App Store Connect API key. Signing: fastlane match (readonly)."
  desc "Version comes from RELEASE_VERSION (the git tag); build number is the"
  desc "next TestFlight build number. Both are injected at archive time."
  lane :beta do
    # On CI, create a temporary UNLOCKED keychain for signing. Without this,
    # match imports the cert into the default keychain and codesign blocks
    # forever waiting for keychain-access approval that never comes (there is
    # no GUI on the runner). No-op locally when CI is unset.
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT_BASE64"),
      is_key_content_base64: true,
      in_house: false
    )

    # Pull the distribution cert + provisioning profile from the match repo.
    # readonly: never mint new credentials from CI — populate them locally.
    match(
      type: "appstore",
      readonly: true,
      app_identifier: APP_IDENTIFIER,
      api_key: api_key
    )

    # match exports the exact resolved profile name (it carries a timestamp
    # suffix, e.g. "match AppStore com.simantstha.vital 1783368200"), so read
    # it rather than hardcoding — otherwise the export mapping won't match.
    profile_name = ENV.fetch("sigh_#{APP_IDENTIFIER}_appstore_profile-name")

    # Next build number = (highest already on TestFlight) + 1. Falls back to 1
    # for the very first upload (initial_build_number).
    build_number = latest_testflight_build_number(
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      initial_build_number: 0
    ) + 1

    version = ENV.fetch("RELEASE_VERSION")

    # Force manual signing with the match-installed profile so the archive is
    # deterministic on a fresh CI runner (no automatic-signing guesswork).
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Vital/Vital.xcodeproj",
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      bundle_identifier: APP_IDENTIFIER,
      targets: ["Vital"]
    )

    build_app(
      project: "Vital/Vital.xcodeproj",
      scheme: "Vital",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Vital.ipa",
      # Stamp version + build via build settings so they reach the Info.plist.
      xcargs: "MARKETING_VERSION=#{version} CURRENT_PROJECT_VERSION=#{build_number}",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      # Don't block the CI job on Apple's server-side processing.
      skip_waiting_for_build_processing: true
    )
  end

  desc "One-off maintenance: enable the Push Notifications capability on the"
  desc "App ID and force-regenerate the App Store profile so it carries the"
  desc "aps-environment entitlement the app now declares. Idempotent."
  lane :fix_push_capability do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT_BASE64"),
      is_key_content_base64: true,
      in_house: false
    )

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    bundle_id = Spaceship::ConnectAPI::BundleId.find(APP_IDENTIFIER)
    UI.user_error!("App ID #{APP_IDENTIFIER} not found on this team") if bundle_id.nil?

    push_type = Spaceship::ConnectAPI::BundleIdCapability::Type::PUSH_NOTIFICATIONS
    if bundle_id.get_capabilities.any? { |c| c.capability_type == push_type }
      UI.message("Push Notifications capability already enabled on #{APP_IDENTIFIER}")
    else
      bundle_id.create_capability(push_type)
      UI.success("Enabled Push Notifications capability on #{APP_IDENTIFIER}")
    end

    # Re-mint the profile so it picks up the capability. Unlike `beta`, this
    # writes to the certs repo — the deploy key must allow write access.
    match(
      type: "appstore",
      readonly: false,
      force: true,
      app_identifier: APP_IDENTIFIER,
      api_key: api_key
    )
  end
end
