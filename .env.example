# Vital — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# Only keys the codebase actually reads are listed here.

# Local dev Postgres
DATABASE_URL=

# Claude AI (coach, meal reactions, proactive analysis)
ANTHROPIC_API_KEY=

# CalorieNinjas (free-text nutrition estimate fallback)
CALORIENINJAS_API_KEY=

# USDA FoodData Central (nutrition candidate search + barcode GTIN lookup;
# free key: https://api.data.gov/signup)
USDA_FDC_API_KEY=

# ElevenLabs (coach voice TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Auth (jose-based session JWT + Sign in with Apple)
# Set matching values via `fly secrets set` before deploying middleware.ts changes.
SESSION_JWT_SECRET=
APPLE_BUNDLE_ID=
# Dev-auth bypass (env-gated; unset this in production once SIWA is wired up)
DEV_AUTH_SECRET=

# Local data directory for file-backed stores (memory templates, etc.)
VITAL_DATA_DIR=
